# Образец прод-окружения для docker-compose.prod.yml.
# Скопировать в .env на сервере, заполнить, выставить права: chmod 600 .env
# НЕ коммитить заполненный .env. Полная матрица — docs/nomad/env-matrix.md.

# --- Домены (Caddy + зашиваются в бандлы фронтов на build) ---
AROMA_DOMAIN=nomad.example.com
MASTER_DOMAIN=master.nomad.example.com
API_DOMAIN=api.nomad.example.com
# Email для ACME/Let's Encrypt уведомлений
ACME_EMAIL=ops@example.com
# Публичный URL backend — зашивается в оба фронта (build-arg VITE_API_BASE_URL).
# Обычно https://${API_DOMAIN}. При смене нужен пересбор фронтов (--build).
PUBLIC_API_URL=https://api.nomad.example.com

# --- Backend ---
# Managed Postgres облака. Обязательно sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/nomad?schema=public&sslmode=require
# Сгенерировать: openssl rand -hex 32 (независимые значения!)
NOMAD_AUTOMATION_KEY=
NOMAD_TOKEN_SECRET=
NOMAD_TOKEN_TTL_HOURS=24

# --- Telegram-бот ---
# Токен от @BotFather. NOMAD_BACKEND_AUTOMATION_TOKEN боту не задаём отдельно —
# compose подставляет в него NOMAD_AUTOMATION_KEY (должны совпадать).
TELEGRAM_BOT_TOKEN=

# --- Bootstrap первого admin (одноразово, см. runbook; можно НЕ держать в .env) ---
# NOMAD_BOOTSTRAP_ADMIN_LOGIN=nomad-admin
# NOMAD_BOOTSTRAP_ADMIN_NAME=Nomad Admin
# NOMAD_BOOTSTRAP_ADMIN_PASSWORD=
