generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model IntroCard {
  id          String   @id
  step        Int      @unique
  title       String
  description String
  bullets     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StaffAccount {
  id           String   @id
  login        String   @unique
  passwordHash String
  passwordSalt String
  name         String
  role         String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active])
}

model DailyAccessCode {
  id        String   @id
  codeValue String
  codeHash  String
  codeSalt  String
  codeLabel String
  active    Boolean  @default(true)
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, startsAt, endsAt])
}

model TelegramRecipient {
  id        String   @id
  chatId    String
  label     String
  scope     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chatId, scope])
  @@index([scope, active])
}

model TelegramOperator {
  id                  String    @id
  name                String
  phone               String    @unique
  active              Boolean   @default(true)
  linkedChatId        String?   @unique
  linkedTelegramUserId String?
  linkedUsername      String?
  linkedDisplayName   String?
  linkedAt            DateTime?
  lastCodeRequestedAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([active])
  @@index([linkedChatId])
}

model TelegramAutomationState {
  id                    String    @id
  lastHeartbeatAt       DateTime?
  lastRotateAt          DateTime?
  lastRotateCodeId      String?
  lastRotateCodeValue   String?
  lastBroadcastAt       DateTime?
  lastBroadcastCodeId   String?
  lastBroadcastCodeValue String?
  lastBroadcastDayKey   String?
  lastRequestAt         DateTime?
  lastRequestChatId     String?
  lastRequestOperatorId String?
  lastRequestOperatorName String?
  lastRequestPhone      String?
  lastRequestCodeId     String?
  lastRequestCodeValue  String?
  lastErrorAt           DateTime?
  lastErrorMessage      String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model AuditEvent {
  id          String   @id @default(uuid())
  actorLogin  String
  actorName   String
  actorRole   String
  action      String
  entityType  String
  entityId    String
  entityLabel String
  details     String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, createdAt])
  @@index([actorLogin, createdAt])
}

model Tobacco {
  id              String            @id
  manufacturer    String
  lineName        String            @default("")
  name            String
  alias           String?
  description     String?
  sourceKind      String?
  sourceUrl       String?
  sourceExternalId String?          @unique
  sourceNumericId String?
  country         String?
  officialStrength String?
  communityStrength String?
  productionStatus String?
  imageUrl        String?
  rawSourceTags   String?
  flavorProfiles  String
  flavors         String
  flavorTags      String
  inStock         Boolean           @default(true)
  archived        Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  mixComponents   MixComponent[]

  @@unique([sourceKind, sourceNumericId])
  @@index([manufacturer, lineName, name])
  @@index([inStock])
  @@index([archived])
  @@index([sourceKind])
}

model FlavorProfileCatalog {
  key         String   @id
  label       String
  tobaccoCount Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FlavorCatalog {
  key         String   @id
  label       String
  tobaccoCount Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FlavorTagCatalog {
  key         String   @id
  label       String
  tobaccoCount Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SourceTagMapping {
  id                  String   @id
  sourceKind          String
  sourceTag           String
  normalizedSourceTag String
  flavorProfiles      String
  flavors             String
  flavorTags          String
  tobaccoCount        Int      @default(0)
  unmapped            Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([sourceKind, normalizedSourceTag])
  @@index([sourceKind])
}

model Mix {
  id              String            @id
  name            String
  description     String
  flavorProfiles  String
  flavors         String
  flavorTags      String
  available       Boolean           @default(true)
  popularity      Int               @default(0)
  baseAvgRating   Float             @default(4.5)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  components      MixComponent[]
  railMixes       RailMix[]
  ratings         MixRating[]
  smokeEvents     SmokeCtaEvent[]
}

model MixComponent {
  id         String      @id @default(uuid())
  mixId      String
  tobaccoId   String
  proportion  Int         @default(50)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  mix         Mix    @relation(fields: [mixId], references: [id], onDelete: Cascade)
  tobacco     Tobacco @relation(fields: [tobaccoId], references: [id], onDelete: Restrict)

  @@unique([mixId, tobaccoId])
  @@index([mixId])
  @@index([tobaccoId])
}

model Rail {
  id          String         @id
  name        String
  description String
  type        String
  active      Boolean        @default(true)
  isSystem    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  mixes       RailMix[]

  @@index([type])
  @@index([active])
}

model RailMix {
  id         String    @id @default(uuid())
  railId     String
  mixId      String
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())
  rail       Rail @relation(fields: [railId], references: [id], onDelete: Cascade)
  mix        Mix  @relation(fields: [mixId], references: [id], onDelete: Cascade)

  @@unique([railId, mixId])
  @@index([railId])
  @@index([mixId])
}

model SmokeCtaEvent {
  id        String    @id @default(uuid())
  mixId     String
  createdAt DateTime  @default(now())
  mix       Mix  @relation(fields: [mixId], references: [id], onDelete: Cascade)

  @@index([mixId])
}

model MixRating {
  id        String    @id @default(uuid())
  mixId     String
  value     Int
  source    String    @default("guest")
  createdAt DateTime  @default(now())
  mix       Mix  @relation(fields: [mixId], references: [id], onDelete: Cascade)

  @@index([mixId])
  @@index([createdAt])
}
