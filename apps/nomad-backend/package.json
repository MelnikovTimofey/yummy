{
  "name": "nomad-backend",
  "private": true,
  "version": "0.1.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "test": "tsx --test --test-concurrency=1 src/**/*.test.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:start": "docker compose -f docker-compose.yml up -d db",
    "db:stop": "docker compose -f docker-compose.yml down",
    "prisma:generate": "prisma generate",
    "prisma:dbpush": "prisma db push",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@prisma/client": "^5.22.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "prisma": "^5.22.0",
    "tsx": "^4.15.7",
    "typescript": "^5.5.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
