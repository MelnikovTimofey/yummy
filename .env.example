# Пример переменных для docker compose. Скопируйте в .env и заполните секреты.

# Backend
NOMAD_AUTOMATION_KEY=nomad-local-automation-key
NOMAD_TOKEN_SECRET=nomad-local-secret
NOMAD_TOKEN_TTL_HOURS=24

# Web → backend (зашивается в bundle при build)
AROMA_VITE_API_BASE_URL=http://localhost:3021
MASTER_VITE_API_BASE_URL=http://localhost:3021

# Telegram bot (TELEGRAM_BOT_TOKEN обязателен, остальное опционально)
TELEGRAM_BOT_TOKEN=
