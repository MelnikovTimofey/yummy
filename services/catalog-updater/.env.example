DATABASE_URL=postgresql://yummy:yummy@localhost:5432/yummy
PORT=3011
HOST=0.0.0.0
LOG_LEVEL=info

# Optional: simple protection for POST /jobs/refresh
UPDATER_API_KEY=

# Test-only sources switch (disabled by default)
CATALOG_ALLOW_TEST_SOURCES=false

# Optional: custom seed location
CATALOG_SEED_DIR=../../backend/seed

# HookahPortal test source params
HOOKAHPORTAL_TOBACCOS_SITEMAP_URL=https://hookahportal.ru/tobaccos.xml
HOOKAHPORTAL_MIXES_SITEMAP_URL=https://hookahportal.ru/mixes.xml
HOOKAHPORTAL_MAX_TOBACCOS=250
HOOKAHPORTAL_MAX_MIXES=250
HOOKAHPORTAL_DELAY_MS=100
HOOKAHPORTAL_CONCURRENCY=12
HOOKAHPORTAL_TIMEOUT_MS=15000
HOOKAHPORTAL_CACHE_DIR=./cache/hookahportal
HOOKAHPORTAL_CACHE_READ=true
HOOKAHPORTAL_CACHE_WRITE=true
